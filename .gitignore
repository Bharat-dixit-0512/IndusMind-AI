# ==============================================================================
# Application Runtime Data
# ==============================================================================
# Ignore dynamic files in uploads, vector store, and reports, but keep folder structure via .gitkeep
backend/uploads/*
!backend/uploads/.gitkeep

backend/vector_store/*
!backend/vector_store/.gitkeep

backend/reports/*
!backend/reports/.gitkeep
